# ============================================================
# SERVER CONFIG
# ============================================================
NODE_ENV=development
PORT=5000

# ============================================================
# MONGODB
# ============================================================
MONGO_URI=mongodb://localhost:27017/location_ecommerce
# Production example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/location_ecommerce?retryWrites=true&w=majority

# ============================================================
# JWT
# ============================================================
